<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.library.controller.MemberController"
            stylesheets="@../css/members.css">

    <top>
        <HBox spacing="10" styleClass="toolbar">
            <children>
                <TextField fx:id="searchField" promptText="Search members by name, email, or phone" HBox.hgrow="ALWAYS"/>
                <Button text="Search" onAction="#handleSearch"/>
                <Button text="Clear" onAction="#handleClearSearch"/>
            </children>
        </HBox>
    </top>

    <left>
        <VBox spacing="10" prefWidth="340" styleClass="form-panel">
            <children>
                <Label text="Member Form" styleClass="section-label"/>

                <Label text="Full Name"/>
                <TextField fx:id="nameField" promptText="Full Name"/>

                <Label text="Email"/>
                <TextField fx:id="emailField" promptText="email@example.com"/>

                <Label text="Phone"/>
                <TextField fx:id="phoneField" promptText="+1-555-000-0000"/>

                <Label text="Membership Date"/>
                <DatePicker fx:id="membershipDatePicker" prefWidth="320"/>

                <HBox spacing="10">
                    <children>
                        <Button text="Save Member" onAction="#handleSave" styleClass="primary-button"/>
                        <Button text="Clear Form" onAction="#handleClearForm"/>
                    </children>
                </HBox>
                <Button text="Delete Selected" onAction="#handleDelete" styleClass="danger-button" prefWidth="320"/>

                <Separator/>

                <Label fx:id="eligibilityLabel" text="" wrapText="true"/>
            </children>
        </VBox>
    </left>

    <center>
        <TableView fx:id="memberTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                <TableColumn fx:id="nameColumn" text="Full Name" prefWidth="200"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="130"/>
                <TableColumn fx:id="membershipDateColumn" text="Member Since" prefWidth="110"/>
                <TableColumn fx:id="eligibleColumn" text="Eligible" prefWidth="70"/>
            </columns>
        </TableView>
    </center>

</BorderPane>
