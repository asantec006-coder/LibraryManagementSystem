<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.library.controller.BooksController"
      stylesheets="@../css/common.css,@../css/books.css" styleClass="app-root">

    <fx:include fx:id="sidebar" source="common/Sidebar.fxml" HBox.hgrow="NEVER"/>

    <VBox HBox.hgrow="ALWAYS">
        <fx:include fx:id="topBar" source="common/TopBar.fxml"/>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-content" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <VBox spacing="16">
                <padding><Insets top="20" right="30" bottom="30" left="30"/></padding>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Search books or authors..."
                               styleClass="books-search-field" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="filterCombo" promptText="All"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Add New Book" onAction="#onAdd" styleClass="btn-primary"/>
                </HBox>

                <Label fx:id="summaryLabel" text="8 books found · 28 copies available" styleClass="books-summary"/>

                <FlowPane fx:id="bookCardsPane" hgap="20" vgap="20"/>
            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
