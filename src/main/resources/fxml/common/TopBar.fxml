<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.library.controller.common.TopBarController"
      styleClass="topbar" alignment="CENTER_LEFT" spacing="20">
    <padding><Insets top="18" right="30" bottom="18" left="30"/></padding>

    <VBox>
        <Label fx:id="titleLabel" text="Page Title" styleClass="page-header-title"/>
        <Label fx:id="subtitleLabel" text="Page subtitle" styleClass="page-header-subtitle"/>
    </VBox>

    <Region HBox.hgrow="ALWAYS"/>

    <TextField fx:id="searchField" promptText="Search books, members..." styleClass="topbar-search"
               onAction="#onSearch"/>

    <StackPane styleClass="topbar-icon-btn" onMouseClicked="#goToNotifications">
        <SVGPath content="M 12 22 C 13.1 22 14 21.1 14 20 L 10 20 C 10 21.1 10.9 22 12 22 Z M 18 16 L 18 11 C 18 7.93 16.36 5.36 13.5 4.68 L 13.5 4 C 13.5 3.17 12.83 2.5 12 2.5 C 11.17 2.5 10.5 3.17 10.5 4 L 10.5 4.68 C 7.63 5.36 6 7.92 6 11 L 6 16 L 4 18 L 4 19 L 20 19 L 20 18 L 18 16 Z"
                 style="-fx-fill: #101828;"/>
        <StackPane styleClass="topbar-badge" StackPane.alignment="TOP_RIGHT">
            <!-- Badge count removed to look cleaner, or can just be a small red dot if preferred, but since they wanted it as a button, let's keep the circle but empty or standard -->
            <Label text="" style="-fx-text-fill: white; -fx-font-size: 9px; -fx-font-weight: bold;"/>
        </StackPane>
    </StackPane>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <StackPane styleClass="topbar-avatar">
            <SVGPath content="M 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 C 17.52 22 22 17.52 22 12 C 22 6.48 17.52 2 12 2 Z M 12 6 C 13.93 6 15.5 7.57 15.5 9.5 C 15.5 11.43 13.93 13 12 13 C 10.07 13 8.5 11.43 8.5 9.5 C 8.5 7.57 10.07 6 12 6 Z M 12 20 C 9.97 20 7.57 19.18 5.86 17.12 C 7.55 15.8 9.68 15 12 15 C 14.32 15 16.45 15.8 18.14 17.12 C 16.43 19.18 14.03 20 12 20 Z"
                     style="-fx-fill: white;" scaleX="0.9" scaleY="0.9"/>
        </StackPane>
        <Label fx:id="topbarUserName" text="Admin" styleClass="topbar-username"/>
    </HBox>

</HBox>
