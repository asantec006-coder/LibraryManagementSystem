<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.library.controller.BookController"
            stylesheets="@../css/books.css">
    
    <top>
        <HBox spacing="10" styleClass="toolbar">
            <children>
                <TextField fx:id="searchField" promptText="Search books by title, author, or ISBN" HBox.hgrow="ALWAYS"/>
                <Button text="Search" onAction="#handleSearch"/>
                <Button text="Clear" onAction="#handleClearSearch"/>
            </children>
        </HBox>
    </top>
    
    <left>
        <VBox spacing="10" prefWidth="340" styleClass="form-panel">
            <children>
                <Label text="Book Form" styleClass="section-label"/>
                
                <Label text="Book Type"/>
                <ComboBox fx:id="typeComboBox" prefWidth="320">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Physical"/>
                            <String fx:value="E-Book"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                
                <Label text="Title"/>
                <TextField fx:id="titleField" promptText="Title"/>
                
                <Label text="Author"/>
                <TextField fx:id="authorField" promptText="Author"/>
                
                <Label text="ISBN"/>
                <TextField fx:id="isbnField" promptText="ISBN"/>
                
                <Label text="Genre"/>
                <TextField fx:id="genreField" promptText="Genre"/>
                
                <!-- Physical Book Specific Field -->
                <VBox fx:id="physicalGroup" spacing="5">
                    <children>
                        <Label text="Shelf Location"/>
                        <TextField fx:id="shelfLocationField" promptText="e.g. Aisle 3, Shelf B"/>
                    </children>
                </VBox>
                
                <!-- EBook Specific Fields -->
                <VBox fx:id="ebookGroup" spacing="5">
                    <children>
                        <Label text="Download URL"/>
                        <TextField fx:id="downloadUrlField" promptText="e.g. http://example.com/book.pdf"/>
                        <Label text="File Size (MB)"/>
                        <TextField fx:id="fileSizeField" promptText="e.g. 4.5"/>
                    </children>
                </VBox>
                
                <CheckBox fx:id="availableCheckBox" text="Available" selected="true"/>
                
                <HBox spacing="10">
                    <children>
                        <Button text="Save Book" onAction="#handleSave" styleClass="primary-button"/>
                        <Button text="Clear Form" onAction="#handleClearForm"/>
                    </children>
                </HBox>
                <Button text="Delete Selected" onAction="#handleDelete" styleClass="danger-button" prefWidth="320"/>
            </children>
        </VBox>
    </left>
    
    <center>
        <TableView fx:id="bookTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="85"/>
                <TableColumn fx:id="titleColumn" text="Title" prefWidth="200"/>
                <TableColumn fx:id="authorColumn" text="Author" prefWidth="150"/>
                <TableColumn fx:id="isbnColumn" text="ISBN" prefWidth="110"/>
                <TableColumn fx:id="genreColumn" text="Genre" prefWidth="100"/>
                <TableColumn fx:id="availableColumn" text="Available" prefWidth="75"/>
                <TableColumn fx:id="detailsColumn" text="Details" prefWidth="200"/>
            </columns>
        </TableView>
    </center>
    
</BorderPane>
