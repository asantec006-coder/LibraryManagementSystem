<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<!--
    Dashboard, restyled to match the "Bookish" reference layout: a stat-card
    row, then a trend chart alongside a dark highlighted stat card + a
    category breakdown chart, then a data table. Every number is still
    computed from the real database (AnalyticsService / LoanService /
    BookService) — the "Outstanding Fines" card and "Most Borrowed Books"
    table are new, real, data-backed additions (see DashboardController),
    not decorative placeholders.
-->
<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.library.controller.DashboardController"
      stylesheets="@../css/common.css,@../css/dashboard.css" styleClass="app-root">

    <fx:include fx:id="sidebar" source="common/Sidebar.fxml" HBox.hgrow="NEVER"/>

    <VBox HBox.hgrow="ALWAYS">
        <fx:include fx:id="topBar" source="common/TopBar.fxml"/>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-content" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <VBox spacing="20">
                <padding><Insets top="20" right="30" bottom="30" left="30"/></padding>

                <!-- Stat cards -->
                <HBox spacing="20">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="14">
                        <HBox alignment="CENTER_LEFT">
                            <StackPane styleClass="stat-icon-box stat-icon-blue"><Text text="&#128218;"/></StackPane>
                        </HBox>
                        <Label fx:id="totalBooksLabel" text="0" styleClass="stat-value"/>
                        <Label text="Total Books" styleClass="stat-label"/>
                    </VBox>

                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="14">
                        <HBox alignment="CENTER_LEFT">
                            <StackPane styleClass="stat-icon-box stat-icon-green"><Text text="&#128101;"/></StackPane>
                        </HBox>
                        <Label fx:id="activeMembersLabel" text="0" styleClass="stat-value"/>
                        <Label text="Active Members" styleClass="stat-label"/>
                    </VBox>

                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="14">
                        <HBox alignment="CENTER_LEFT">
                            <StackPane styleClass="stat-icon-box stat-icon-purple"><Text text="&#128209;"/></StackPane>
                        </HBox>
                        <Label fx:id="borrowedBooksLabel" text="0" styleClass="stat-value"/>
                        <Label text="Books Borrowed" styleClass="stat-label"/>
                    </VBox>

                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="14">
                        <HBox alignment="CENTER_LEFT">
                            <StackPane styleClass="stat-icon-box stat-icon-red"><Text text="&#9888;"/></StackPane>
                        </HBox>
                        <Label fx:id="overdueBooksLabel" text="0" styleClass="stat-value"/>
                        <Label text="Overdue Books" styleClass="stat-label"/>
                    </VBox>
                </HBox>

                <!-- Trend chart + right column (highlighted fines card + category chart) -->
                <HBox spacing="20">
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" spacing="10" minWidth="320">
                        <HBox alignment="CENTER_LEFT">
                            <VBox>
                                <Label text="Borrowing Trend" styleClass="section-title"/>
                                <Label text="Books borrowed per month" styleClass="section-subtitle"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <ComboBox fx:id="rangeCombo"/>
                        </HBox>
                        <LineChart fx:id="trendChart" legendVisible="false" createSymbols="false"
                                   VBox.vgrow="ALWAYS" prefHeight="260">
                            <xAxis><CategoryAxis fx:id="trendXAxis"/></xAxis>
                            <yAxis><NumberAxis fx:id="trendYAxis"/></yAxis>
                        </LineChart>
                    </VBox>

                    <VBox prefWidth="320" minWidth="280" HBox.hgrow="SOMETIMES" spacing="20">
                        <VBox styleClass="highlight-card" spacing="10">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="OUTSTANDING FINES" styleClass="highlight-card-label"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <StackPane style="-fx-background-color: rgba(255,255,255,0.12); -fx-background-radius: 10px; -fx-min-width:34; -fx-min-height:34; -fx-max-width:34; -fx-max-height:34;">
                                    <Text text="&#9888;" style="-fx-fill: white; -fx-font-size: 14px;"/>
                                </StackPane>
                            </HBox>
                            <Label fx:id="outstandingFinesLabel" text="$0.00" styleClass="highlight-card-value"/>
                            <Label fx:id="overdueCountLabel" text="0 overdue loans" styleClass="highlight-card-note"/>
                            <Button text="View Overdue Loans" onAction="#onViewOverdue" styleClass="btn-secondary" maxWidth="Infinity"
                                    style="-fx-background-color: white; -fx-text-fill: #16224a;"/>
                        </VBox>

                        <VBox styleClass="content-card" spacing="10" VBox.vgrow="ALWAYS">
                            <Label text="Popular Categories" styleClass="section-title"/>
                            <Label text="By number of loans" styleClass="section-subtitle"/>
                            <PieChart fx:id="categoryPieChart" legendVisible="true" VBox.vgrow="ALWAYS" prefHeight="200"/>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- Most borrowed books -->
                <VBox styleClass="content-card" spacing="14">
                    <Label text="Most Borrowed Books" styleClass="section-title"/>
                    <Label text="All-time, by number of loans" styleClass="section-subtitle"/>
                    <TableView fx:id="mostBorrowedTable" styleClass="data-table" VBox.vgrow="ALWAYS" prefHeight="220">
                        <columns>
                            <TableColumn fx:id="mbTitleColumn" text="BOOK TITLE" prefWidth="320"/>
                            <TableColumn fx:id="mbAuthorColumn" text="AUTHOR" prefWidth="220"/>
                            <TableColumn fx:id="mbLoansColumn" text="TIMES BORROWED" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
